# Variables d'environnement à configurer sur Railway
# Copie ces valeurs depuis Replit > Secrets

# Base de données PostgreSQL (Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://...

# Port (Railway injecte automatiquement)
PORT=3000

# Node environment
NODE_ENV=production

# Clés Supabase (pour Safi Runner / Grado)
SUPABASE_URL=https://ngfmuysddnixtbbguakr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Clé API livreur
LIVREUR_API_KEY=...

# Push notifications (si utilisé)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
