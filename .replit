modules = ["nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Manager Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Driver App"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Manager Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23696 BASE_PATH=/ pnpm --filter @workspace/delivery-manager run dev"
waitForPort = 23696

[[workflows.workflow]]
name = "Driver App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=18861 BASE_PATH=/driver-app/ pnpm --filter @workspace/driver-app run dev"
waitForPort = 18861

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["nano"]

[[ports]]
localPort = 3001
externalPort = 6800

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 18861
externalPort = 6000

[[ports]]
localPort = 23696
externalPort = 80

[[ports]]
localPort = 23697
externalPort = 3000

[[ports]]
localPort = 23698
externalPort = 3002

[[ports]]
localPort = 23699
externalPort = 5000

[[ports]]
localPort = 24492
externalPort = 4200

